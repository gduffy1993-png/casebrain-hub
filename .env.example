NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-or-service-role-key-here
SUPABASE_STORAGE_BUCKET=casebrain-documents

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up

# Optional: show Clerk sign-in test UI on the marketing homepage footer (client)
# NEXT_PUBLIC_SHOW_CLERK_TEST=1

# Local eval: GET /api/cases without cookies — set org (defence-plan-chat resolves org from case id when x-eval: 1).
# EVAL_ORG_ID=
# EVAL_USER_ID=

OPENAI_API_KEY=sk-your-openai-api-key-here

OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_LETTER_MODEL=gpt-4o-mini


REDACTION_SECRET=generate-a-long-random-secret-here
FILE_UPLOAD_MAX_MB=80

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
